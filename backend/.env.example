# Copy this file to .env and adjust if needed.
# Used by the Go server (added in Phase 2).

DATABASE_URL=postgres://humanitarian:humanitarian_dev_password@localhost:5435/humanitarian?sslmode=disable

# Server
HTTP_PORT=8080
APP_ENV=development

# OTP (Phase 3a + 19)
# Demo mode lets you skip the real OTPIQ gateway during development.
# When enabled, POST /api/auth/otp/request with {"mode":"demo"} returns the
# code in the JSON response instead of sending an SMS.
OTP_DEMO_ENABLED=1
OTP_DEMO_CODE=123456
# Per-IP rate limit for OTP requests (default 10/hour).
OTP_IP_MAX_REQUESTS_PER_HOUR=10

# OTPIQ (Phase 19) — real-mode delivery via WhatsApp with SMS fallback.
# Sign up at https://otpiq.com to get a key (format: sk_live_… / sk_test_…).
OTPIQ_API_KEY=
# whatsapp-sms = try WhatsApp first, fall back to SMS automatically.
OTPIQ_PROVIDER=whatsapp-sms
# Optional 11-char sender id; leave blank for OTPIQ default.
OTPIQ_SENDER_ID=

# Firebase Cloud Messaging (FCM HTTP v1)
# Drop your service-account JSON at the path below and the server picks it up
# at startup. Without it, in-DB notifications still work but no push is delivered.
FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json
