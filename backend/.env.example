# Copy this file to .env and adjust if needed.
# Used by the Go server (added in Phase 2).

DATABASE_URL=postgres://humanitarian:humanitarian_dev_password@localhost:5435/humanitarian?sslmode=disable

# Server
# Locally we use HTTP_PORT. On Railway/Heroku/etc. the platform injects PORT,
# which the server prefers automatically — no change needed for deploys.
HTTP_PORT=8080
APP_ENV=development

# CORS — origins allowed to call the API from a browser (the admin dashboard).
# Comma-separated list, or "*" / empty to allow any origin. Auth is via Bearer
# token (not cookies), so "*" is safe. In production set this to your dashboard
# URL, e.g. https://dashboard.up.railway.app
CORS_ALLOWED_ORIGINS=*

# Migrations — set to 1 to auto-apply backend/migrations/*.sql on startup
# (each runs once, tracked in schema_migrations). Use this on a FRESH database
# such as a new Railway Postgres. Leave unset for an existing local DB.
RUN_MIGRATIONS=
# Where the .sql files live relative to the working dir (default ./migrations).
MIGRATIONS_DIR=./migrations

# OTP (Phase 3a + 19)
# Demo mode lets you skip the real OTPIQ gateway during development.
# When enabled, POST /api/auth/otp/request with {"mode":"demo"} returns the
# code in the JSON response instead of sending an SMS.
OTP_DEMO_ENABLED=1
OTP_DEMO_CODE=123456
# Per-IP rate limit for OTP requests (default 10/hour).
OTP_IP_MAX_REQUESTS_PER_HOUR=10

# OTPIQ (Phase 19) — real-mode delivery via WhatsApp with SMS fallback.
# Sign up at https://otpiq.com to get a key (format: sk_live_… / sk_test_…).
OTPIQ_API_KEY=
# whatsapp-sms = try WhatsApp first, fall back to SMS automatically.
OTPIQ_PROVIDER=whatsapp-sms
# Optional 11-char sender id; leave blank for OTPIQ default.
OTPIQ_SENDER_ID=

# Firebase Cloud Messaging (FCM HTTP v1)
# Drop your service-account JSON at the path below and the server picks it up
# at startup. Without it, in-DB notifications still work but no push is delivered.
FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json

# Google Sign-In (POST /api/auth/google)
# Comma-separated list of the OAuth Client IDs (Web + iOS + Android, as
# applicable) whose ID tokens the server will accept — create these in the
# Google Cloud Console (APIs & Services → Credentials). Without this set,
# GoogleConfigured() is false and every Google sign-in attempt gets an
# immediate "Google sign-in is not configured on the server" error — this
# was never set anywhere (local, .env.example, or the deploy docs) as of
# this writing, so Google Sign-In has never actually been reachable.
GOOGLE_OAUTH_CLIENT_IDS=

# AI Support Assistant (Phase 29)
# When ANTHROPIC_API_KEY is set, the in-app Support Assistant answers users
# with Claude (role-aware, can suggest in-app navigation). Without it, the
# assistant runs a built-in keyword engine over the same knowledge base, so
# it still works — just without free-form understanding.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-3-5-haiku-latest).
ASSISTANT_MODEL=
