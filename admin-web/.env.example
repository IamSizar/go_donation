# Copy to .env.local if you need to override the proxied default ('').
# When VITE_API_BASE_URL is empty, the SPA hits /api/* which Vite proxies to
# http://localhost:8080. In production builds, set this to your API origin.
VITE_API_BASE_URL=

# Optional local-dev convenience: shows an "Autofill" button on the login
# screen that fills these into the form (never auto-submits). Only read when
# running under `vite dev` (import.meta.env.DEV) — stripped out of
# production builds entirely, so this is safe to leave unset outside local
# dev. Put real values in .env.local (gitignored via *.local), never here.
VITE_DEV_ADMIN_USERNAME=
VITE_DEV_ADMIN_PASSWORD=
